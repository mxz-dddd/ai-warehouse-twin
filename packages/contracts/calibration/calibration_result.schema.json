{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://warehouse-twin.local/contracts/calibration/calibration_result.schema.json",
  "title": "CalibrationResult",
  "type": "object",
  "required": [
    "request_id",
    "warehouse_id",
    "status",
    "mape",
    "confidence_level",
    "summary"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "warehouse_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "CALIBRATED",
        "INSUFFICIENT_DATA",
        "FAILED"
      ]
    },
    "mape": {
      "type": "number"
    },
    "confidence_level": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
